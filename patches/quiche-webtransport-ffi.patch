+// MystralNative addition: expose set_additional_settings to the C FFI so the
+// host can advertise WebTransport HTTP/3 SETTINGS (e.g. SETTINGS_WT_MAX_SESSIONS
+// and SETTINGS_ENABLE_WEBTRANSPORT) which upstream quiche does not handle natively.
+// `pairs` points to `pairs_len * 2` u64 values laid out as [id0, val0, id1, val1, ...].
+// Returns 0 on success, a negative quiche_h3_error on failure.
+#[no_mangle]
+pub extern "C" fn quiche_h3_config_set_additional_settings(
+    config: &mut h3::Config, pairs: *const u64, pairs_len: usize,
+) -> std::os::raw::c_int {
+    if pairs.is_null() {
+        return h3::Error::SettingsError.to_c() as std::os::raw::c_int;
+    }
+
+    let flat = unsafe { std::slice::from_raw_parts(pairs, pairs_len * 2) };
+    let settings: Vec<(u64, u64)> =
+        flat.chunks_exact(2).map(|c| (c[0], c[1])).collect();
+
+    match config.set_additional_settings(settings) {
+        Ok(_) => 0,
+        Err(e) => e.to_c() as std::os::raw::c_int,
+    }
+}
+
 #[no_mangle]
 pub extern "C" fn quiche_h3_config_free(config: *mut h3::Config) {
     drop(unsafe { Box::from_raw(config) });
